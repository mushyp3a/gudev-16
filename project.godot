; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="gudev-16"
run/main_scene="res://scenes/replay-testing-scene-2.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

global="*res://global.gd"
levels_completed="*res://levels_completed.gd"
ShaderManager="*res://scripts/shader-manager.gd"
Music="*res://scenes/sounds/music.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/size/borderless=true
window/size/always_on_top=true
window/stretch/mode="canvas_items"
display_server/driver.linuxbsd="wayland"

[dotnet]

project/assembly_name="gudev-16"

