}

[connection signal="mouse_entered" from="MarginContainer/VBoxContainer/Start Button" to="Player/Area2D" method="play_run"]
[connection signal="mouse_exited" from="MarginContainer/VBoxContainer/Start Button" to="Player/Area2D" method="play_idle"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/Start Button" to="." method="_on_start_button_pressed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/VBoxContainer/Lore" to="." method="_on_lore_pressed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/VBoxContainer/Credits" to="." method="_on_credits_pressed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/VBoxContainer/Quit" to="." method="_on_quit_pressed"]
